# JWT secret (required) — generate one with: openssl rand -hex 32
JWT_SECRET=

# Allow new user registration (set to false after creating your account)
ALLOW_REGISTRATION=true

# Database — leave unset for SQLite (recommended for self-hosting)
# For PostgreSQL, uncomment and set your connection string:
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# If you're running behind HTTPS (e.g. Traefik, Caddy, nginx), set these:
# CORS_ORIGINS=https://your-domain.com
# COOKIE_SECURE=true
