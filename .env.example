# PostgreSQL connection string (Railway injects this automatically in production).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diatrack

# better-auth: strong random secret (e.g. `openssl rand -base64 32`). Required.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string

# Public base URL of the app. Used by better-auth and the oRPC SSR client.
BETTER_AUTH_URL=http://localhost:3000

# Set to "true" to allow new account registration via the UI. Off by default.
ALLOW_REGISTRATION=false

# Optional: email to promote to admin via `bun run db:seed`.
ADMIN_EMAIL=

# Port the server listens on (Railway injects PORT automatically).
PORT=3000
